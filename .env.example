# Diamond ERC-3643 — Environment
# Copy to .env and fill in your values

# ── Diamond Contract ──
DIAMOND_ADDRESS=0xAb07CEf1BEeDBb30F5795418c79879794b31C521

# ── RPC (Polygon Amoy Testnet) ──
RPC_URL=https://rpc-amoy.polygon.technology

# ── Indexer ──
START_BLOCK=35301007
INDEXER_PORT=8080

# ── External Contracts (compliance modules + yield distributor) ──
EXTRA_ADDRESSES=0x0c15e06c36b07E44aEe6D49a75554bc7bfFa50D2,0x4B3cCd1F7BB1aF5F41b73e7fE3010023FcD89B44,0xC40Bf7bb339DD4485b1F5c3c0C5FE78DACD9999a,0xa8c6A9AAfd18545bEe6BC734eba702C55beA95dF

# ── Frontend ──
APP_PORT=3000
VITE_INDEXER_URL=http://localhost:8080

# ── Forge Visual (Test Dashboard) ──
FORGE_VISUAL_PORT=3999

# ── Compliance Modules ──
VITE_COUNTRY_RESTRICT_MODULE=0x0c15e06c36b07E44aEe6D49a75554bc7bfFa50D2
VITE_MAX_BALANCE_MODULE=0x4B3cCd1F7BB1aF5F41b73e7fE3010023FcD89B44
VITE_MAX_HOLDERS_MODULE=0xC40Bf7bb339DD4485b1F5c3c0C5FE78DACD9999a

# ── Deploy (optional — only for contract deployment) ──
# PRIVATE_KEY=0x...
# AMOY_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_KEY
# POLYGONSCAN_API_KEY=YOUR_API_KEY
